# ─── App ─────────────────────────────────────────────────────────────────────
PROFILE=balanced                          # lite | balanced | prosumer | full
ENVIRONMENT=development                   # development | production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── PostgreSQL (Neon in prod, Docker locally) ────────────────────────────────
# Local:      postgresql+asyncpg://traffic:traffic@localhost:5432/traffic_ai
# Neon prod:  postgresql+asyncpg://user:pass@ep-xxx.neon.tech/traffic_ai?sslmode=require
DATABASE_URL=postgresql+asyncpg://traffic:traffic@localhost:5432/traffic_ai

# ─── Redis (Upstash in prod, Docker locally) ──────────────────────────────────
# Local:         redis://localhost:6379/0
# Upstash prod:  rediss://default:token@host.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ─── InfluxDB (InfluxDB Cloud in prod, Docker locally) ────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=change-me
INFLUX_ORG=traffic-ai
INFLUX_BUCKET=traffic_metrics

# ─── Docker-only (InfluxDB admin bootstrap) ───────────────────────────────────
INFLUXDB_ADMIN_TOKEN=change-me
INFLUXDB_ADMIN_PASSWORD=change-me

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dev:  http://localhost:5173
# Prod: https://your-frontend.onrender.com (or custom domain)
CORS_ORIGINS=http://localhost:5173

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4

# ─── External data sources (all optional) ─────────────────────────────────────
# Comma-separated list of loop detector API URLs
LOOP_DETECTOR_URLS=

# NOAA weather station IDs (US)
NOAA_STATIONS=

# AEMET weather station IDs (Spain) — needs API key below
AEMET_STATIONS=
AEMET_API_KEY=

# RTSP / MJPEG camera URLs
CAMERA_URLS=

# ─── S3 / Cloudflare R2 (optional — for camera frame storage) ─────────────────
S3_BUCKET=
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
GDPR_MODE=false
